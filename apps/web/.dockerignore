# Files to exclude from the Docker build context.
# Matches .gitignore so the image is reproducible from a clean checkout.

# Local node_modules (we re-install in the deps stage)
**/node_modules
**/.pnpm-store

# Build artifacts
**/.next
**/dist
**/storybook-static

# Test/coverage
**/coverage
**/.vitest

# Editor / OS
.vscode
.idea
.DS_Store

# Local env files (never bake secrets into images)
**/.env
**/.env.local
**/.env.*.local

# CI/git
.git
.github

# Other apps' build outputs we don't need
apps/orchestrator/.venv
apps/orchestrator/__pycache__
**/*.pyc
