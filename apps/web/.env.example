# ─── Database ────────────────────────────────────────────────────────────────
# Local docker-compose Postgres. In Cloud Run this is replaced by the
# Cloud SQL connector socket, populated by Secret Manager.
DATABASE_URL="postgresql://tessar:tessar@localhost:5432/tessar"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: `openssl rand -base64 32`. NEVER reuse across envs.
AUTH_SECRET="replace-me-with-32-bytes-base64"

# Public origin Auth.js uses to build callback URLs. In dev: http://localhost:3000.
# In Cloud Run, the Global LB injects the public hostname; Auth.js reads it
# from the `Host` header (we set `trustHost: true` because Cloud Run is behind
# a Google-managed LB).
AUTH_URL="http://localhost:3000"

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Email (magic link) ──────────────────────────────────────────────────────
# Local: Mailpit (docker-compose). No auth needed; messages land at
# http://localhost:8025.
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
AUTH_EMAIL_FROM="TESSAR <no-reply@tessar.local>"

# Cloud (Resend SMTP gateway). Replace the four lines above with:
#   SMTP_HOST="smtp.resend.com"
#   SMTP_PORT="465"
#   SMTP_USER="resend"
#   SMTP_PASSWORD="${RESEND_API_KEY}"
#   AUTH_EMAIL_FROM="TESSAR <no-reply@tessar.dev>"

# ─── Pub/Sub (run queue) ─────────────────────────────────────────────────────
# Local: docker-compose Pub/Sub emulator on :8085. Use 127.0.0.1 NOT
# `localhost` — Node's gRPC may resolve `localhost` to IPv6 ::1 while the
# emulator container binds IPv4 only, producing a useless
# `Error: undefined undefined: undefined` at publish time.
PUBSUB_EMULATOR_HOST="127.0.0.1:8085"
GOOGLE_CLOUD_PROJECT="tessar-dev"
PUBSUB_RUNS_TOPIC="tessar-runs"

# Cloud: leave PUBSUB_EMULATOR_HOST unset. GOOGLE_CLOUD_PROJECT is injected
# by Cloud Run; PUBSUB_RUNS_TOPIC stays the same.

# ─── Redis (live SSE event tail) ─────────────────────────────────────────────
# Local: docker-compose Redis. Cloud: Memorystore on a private IP.
# Web only reads from Streams (XRANGE + XREAD); writes are worker-side.
REDIS_URL="redis://127.0.0.1:6379"

# ─── Cloud Storage (artifact downloads) ─────────────────────────────────────
# Bucket the orchestrator writes finished packages to. Web only reads,
# always behind /api/runs/[id]/artifact/[kind] (auth-gated proxy).
# Local: STORAGE_EMULATOR_HOST points the SDK at fake-gcs-server. In cloud,
# leave STORAGE_EMULATOR_HOST unset and let ADC + the Cloud Run service
# account handle auth.
GCS_BUCKET="tessar-artifacts-local"
STORAGE_EMULATOR_HOST="http://127.0.0.1:4443"


# === Stripe (Phase 4 - ADR-0009) ============================================
# Test-mode keys from https://dashboard.stripe.com/test/apikeys.
# NEVER commit live-mode keys (sk_live_*). Phase 6 flips to live.
STRIPE_SECRET_KEY=""

# Webhook signing secret. Local dev: run `stripe listen --forward-to
# localhost:3000/api/stripe/webhook` and paste the printed whsec_... here.
# Cloud: register the production endpoint in the Stripe dashboard, copy the
# secret it issues into Secret Manager.
STRIPE_WEBHOOK_SECRET=""

# Public origin Stripe redirects back to after Checkout. Defaults to AUTH_URL
# when unset. Override only if you need to differ (e.g. preview deploys).
# STRIPE_RETURN_URL=""

# === Pre-launch sign-in allowlist =========================================
# Comma-separated, case-insensitive. The bootstrap admin (admin.tessar@gmail.com)
# is ALWAYS allowed even when this is empty/missing. Used to invite teammates
# before public beta. Cleared (or removed) when /signin opens to the public.
AUTH_ALLOWED_EMAILS=""

# === Billing kill-switch ==================================================
# When `true`, /api/checkout creates a real Stripe Checkout Session.
# When anything else (default), /api/checkout marks the run paid in-process
# and enqueues it directly. Stripe routes still respond but receive no
# traffic. Phase 6 flips this to `true` in prod. ADR-0009.
BILLING_ENABLED="false"
