# Orchestrator (apps/orchestrator) — local dev env.
# Mirrors apps/web/.env where appropriate; keeps worker-only knobs separate.
# Loaded automatically by uv/python when running scripts that call dotenv,
# or set via your shell. Cloud Run gets these from Secret Manager.

# ─── Database ────────────────────────────────────────────────────────────────
# Note the `+asyncpg` scheme — required by SQLAlchemy's async engine.
DATABASE_URL="postgresql+asyncpg://tessar:tessar@localhost:5432/tessar"

# ─── Redis (Memorystore in cloud, docker-compose locally) ───────────────────
REDIS_URL="redis://localhost:6379"

# ─── Cloud Storage (fake-gcs-server locally) ────────────────────────────────
GCS_BUCKET="tessar-artifacts-local"
STORAGE_EMULATOR_HOST="http://localhost:4443"

# ─── Pub/Sub (emulator locally) ─────────────────────────────────────────────
PUBSUB_EMULATOR_HOST="localhost:8085"
GOOGLE_CLOUD_PROJECT="tessar-local"
PUBSUB_RUNS_TOPIC="tessar-runs"

# ─── LLM providers (Phase 3+) ───────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=""
VERTEX_PROJECT=""
VERTEX_LOCATION="us-central1"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ─── Web search (Phase 3+) ──────────────────────────────────────────────────
TAVILY_API_KEY=""
BRAVE_SEARCH_API_KEY=""

# ─── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN_ORCHESTRATOR=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
