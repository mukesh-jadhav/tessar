# Copy to .env.local (web) / .env (orchestrator) and fill in.

# --- Web (apps/web) ---
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
EMAIL_FROM="TESSAR <noreply@tessar.local>"

# Stripe (Phase 4+)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Database
DATABASE_URL=postgres://tessar:tessar@localhost:5432/tessar

# Redis
REDIS_URL=redis://localhost:6379

# Cloud Storage (local: fake-gcs-server)
GCS_BUCKET=tessar-artifacts-local
STORAGE_EMULATOR_HOST=http://localhost:4443

# Pub/Sub (local emulator)
PUBSUB_EMULATOR_HOST=localhost:8085
GOOGLE_CLOUD_PROJECT=tessar-local
PUBSUB_RUNS_TOPIC=tessar-runs

# --- Orchestrator (apps/orchestrator) ---
# (uses the same DATABASE_URL, REDIS_URL, GCS_*, PUBSUB_* above)

# LLM providers (Phase 3+)
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Web search (Phase 3+)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Observability
SENTRY_DSN_WEB=
SENTRY_DSN_ORCHESTRATOR=
OTEL_EXPORTER_OTLP_ENDPOINT=
